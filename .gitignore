.gradle
**/build/
!**/src/**/build/

# Ignore Gradle GUI config
gradle-app.setting

# Avoid ignoring Gradle wrapper jar file (.jar files are usually ignored)
!gradle-wrapper.jar

# Avoid ignore Gradle wrappper properties
!gradle-wrapper.properties

# Cache of project
.gradletasknamecache

# Eclipse Gradle plugin generated files
# Eclipse Core
.project
# JDT-specific (Eclipse Java Development Tools)
.classpath
/plan
/Lootr
AGENTS.md
/run-gametest
/bin
/logs
# Forge/Minecraft run directories
/run/
/run-gametest/
/run-client/
/run-server/
/run-data/

# Logs and crash reports
/logs/
/crash-reports/

# Mixin generated files
.mixin.out/

